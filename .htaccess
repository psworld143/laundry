# Enable Rewrite Engine
RewriteEngine On

# Remove index.php from URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# Prevent directory listing
Options -Indexes

# Error pages
ErrorDocument 404 /laundry/index.php
ErrorDocument 403 /laundry/index.php

# Security Headers
<IfModule mod_headers.c>
    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Content Type Protection
    Header set X-Content-Type-Options "nosniff"
    
    # Clickjacking Protection
    Header set X-Frame-Options "SAMEORIGIN"
    
    # HSTS (HTTPS only)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    
    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://www.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com https://www.gstatic.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://www.google.com; frame-src 'self' https://www.google.com; frame-ancestors 'self';"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # Remove server signature
    Header unset Server
    Header set Server "LaundryPro"
</IfModule>

# Block suspicious requests
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Block suspicious user agents
    RewriteCond %{HTTP_USER_AGENT} ^(bot|crawler|spider|scraper) [NC]
    RewriteRule ^ - [F,L]
    
    # Block common exploit attempts
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
    RewriteRule ^ - [F,L]
    
    # Block access to sensitive files
    RewriteRule ^(.*)\.log$ - [F,L]
    RewriteRule ^(.*)\.sql$ - [F,L]
    RewriteRule ^(.*)\.env$ - [F,L]
    RewriteRule ^composer\.json$ - [F,L]
    RewriteRule ^package\.json$ - [F,L]
</IfModule>

# Request filtering
<IfModule mod_reqtimeout.c>
    RequestReadTimeout header=20-40,MinRate=500 body=10,MinRate=500
</IfModule>

# Limit request size
LimitRequestBody 10485760

# Connection settings
<IfModule mod_reqtimeout.c>
    RequestReadTimeout header=20-40,MinRate=500 body=10,MinRate=500
</IfModule>

# PHP Settings
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

